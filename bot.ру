    c.execute('INSERT INTO deals (tag_id, buyer_id, seller_id, amount, currency, created_at) VALUES (?, ?, ?, ?, ?, ?)',
              (tag_id, buyer_id, seller_id, amount, currency, now))
    deal_id = c.lastrowid
    c.execute('UPDATE tags SET status = "sold", buyer_id = ?, sold_at = ? WHERE id = ?', (buyer_id, now, tag_id))
