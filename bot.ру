# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    
    # Пользователи
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        full_name TEXT,
        registered_at TEXT,
        balance INTEGER DEFAULT 0,
        is_admin INTEGER DEFAULT 0,
        is_banned INTEGER DEFAULT 0,
        referrer_id INTEGER DEFAULT NULL,
        ref_earned INTEGER DEFAULT 0
    )''')
    
    # Теги/товары
    c.execute('''CREATE TABLE IF NOT EXISTS tags (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        category TEXT,
        price INTEGER,
        currency TEXT,
        owner_id INTEGER,
        history TEXT,
        proof TEXT,
        status TEXT DEFAULT 'active',
        created_at TEXT
    )''')
    
    # Заявки на добавление тегов
    c.execute('''CREATE TABLE IF NOT EXISTS tag_requests (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        tag_name TEXT,
        category TEXT,
        price INTEGER,
        currency TEXT,
        history TEXT,
        proof TEXT,
        status TEXT DEFAULT 'pending',
        created_at TEXT,
        processed_at TEXT
    )''')
    
    # Заказы
    c.execute('''CREATE TABLE IF NOT EXISTS orders (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        tag_id INTEGER,
        buyer_id INTEGER,
        seller_id INTEGER,
        amount INTEGER,
        currency TEXT,
        status TEXT DEFAULT 'pending',
        payment_proof TEXT,
        created_at TEXT,
        completed_at TEXT
    )''')
    
    # Тикеты поддержки
    c.execute('''CREATE TABLE IF NOT EXISTS tickets (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        username TEXT,
        question TEXT,
        status TEXT DEFAULT 'open',
        taken_by INTEGER DEFAULT NULL,
        created_at TEXT,
        taken_at TEXT,
        answer TEXT,
        answered_at TEXT
    )''')
    
    # Отзывы
    c.execute('''CREATE TABLE IF NOT EXISTS reviews (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        reviewer_id INTEGER,
        seller_id INTEGER,
        tag_id INTEGER,
        rating INTEGER,
        comment TEXT,
        created_at TEXT
    )''')
    
    # Транзакции выводов
    c.execute('''CREATE TABLE IF NOT EXISTS withdrawals (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        amount INTEGER,
        wallet TEXT,
        status TEXT DEFAULT 'pending',
        created_at TEXT,
        processed_at TEXT
    )''')
    
    conn.commit()
    conn.close()

init_db()

