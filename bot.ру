async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    username = update.effective_user.username or str(user_id)
    
    user = get_user(user_id)
    if user and user[6] == 1:
        await update.message.reply_text("🚫 Вы забанены. Обратитесь к админу.")
        return
    
    # Рассылка
    if context.user_data.get("awaiting_broadcast") and (user_id == ADMIN_ID or (user and user[5] == 1)):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 **РАССЫЛКА ОТ АДМИНА**\n\n{text}", parse_mode="Markdown")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ Рассылка отправлена {sent} пользователям.")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # Продажа тега
    if context.user_data.get("awaiting_sell_tag"):
        try:
            parts = text.split("|")
            if len(parts) < 6:
                await update.message.reply_text("❌ Неверный формат. Используй: `название | категория | цена | валюта | история | доказательства`", reply_markup=back_keyboard())
                return
            
            name = parts[0].strip()
            category = parts[1].strip()
            price = int(parts[2].strip())
            currency = parts[3].strip()
            history = parts[4].strip()
            proof = parts[5].strip()
            
            request_id = create_tag_request(user_id, name, category, price, currency, history, proof)
            await update.message.reply_text(f"✅ Заявка #{request_id} отправлена на модерацию!\n\nАдмин рассмотрит её в ближайшее время.", reply_markup=main_keyboard())
            
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=f"📝 **Новая заявка на тег #{request_id}**\n👤 @{username}\n🏷️ {name}\n💰 {price} {currency}\n📖 {history}\n📸 {proof}"
            )
            
            context.user_data["awaiting_sell_tag"] = False
