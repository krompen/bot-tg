def get_seller_rating(seller_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT AVG(rating), COUNT(*) FROM reviews WHERE reviewed_id = ?', (seller_id,))
    result = c.fetchone()
    conn.close()
    avg = round(result[0], 1) if result and result[0] else 0
    count = result[1] if result and result[1] else 0
    return avg, count

