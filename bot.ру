# ========== ОБРАБОТКА ТЕКСТА ==========
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    global LAST_ACTIVITY
    user_id = update.effective_user.id
    text = update.message.text
    username = update.effective_user.username or str(user_id)
    user = get_user(user_id)
    
    # Обновляем активность админа/агента
    if is_admin(user_id) or is_agent(user_id):
        LAST_ACTIVITY = datetime.datetime.now()
    
    # Проверка бана
    if user and user[7] == 1:
        await update.message.reply_text("🚫 Вы забанены.")
        return
    
    # Рассылка
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 **РАССЫЛКА**\n\n{text}\n\n— @{ADMIN_USERNAME}", parse_mode="Markdown")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ Отправлено {sent} пользователям.")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # Продажа тега
    if context.user_data.get("awaiting_sell_tag"):
        try:
            parts = text.split("|")
            if len(parts) < 3:
                await update.message.reply_text("❌ Формат: `название | цена | валюта`")
                return
            
            name = parts[0].strip()
            price = int(parts[1].strip())
            currency = parts[2].strip().lower()
            
            if currency not in ["stars", "ton", "usdt", "usd"]:
                await update.message.reply_text("❌ Валюты: stars, ton, usdt, usd")
                return
            
            req_id = create_tag_request(user_id, name, "5_6", price, currency, "")
            
            await update.message.reply_text(f"✅ **Заявка #{req_id} отправлена!**\n\nТег: {name}\n💰 {price} {currency}", reply_markup=main_keyboard())
            
            await context.bot.send_message(chat_id=ADMIN_ID, text=f"📝 Новая заявка #{req_id}\n👤 @{username}\n🏷️ {name}\n💰 {price} {currency}")
            
            context.user_data["awaiting_sell_tag"] = False
        except ValueError:
            await update.message.reply_text("❌ Цена должна быть числом!")
        except Exception as e:
            await update.message.reply_text(f"❌ Ошибка: {e}")
        return
    
    # Подтверждение оплаты (админ)
    if context.user_data.get("awaiting_confirm_payment") and is_admin(user_id):
        try:
            deal_id = int(text.replace("deal_", ""))
            deal = get_deal(deal_id)
            
            if not deal:
                await update.message.reply_text("❌ Сделка не найдена!")
                context.user_data["awaiting_confirm_payment"] = False
                return
            
            confirm_buyer(deal_id)
            
            seller = get_user_by_id(deal[3])
            await context.bot.send_message(
                chat_id=deal[3],
                text=f"💰 **ПОКУПАТЕЛЬ ОПЛАТИЛ!**\nСделка #{deal_id}\n\nПередай тег покупателю и нажми /confirm_delivery {deal_id}"
            )
            
            await update.message.reply_text(f"✅ Уведомление отправлено продавцу!", reply_markup=main_keyboard())
            context.user_data["awaiting_confirm_payment"] = False
        except:
            await update.message.reply_text("❌ Введи: `deal_123`")
            context.user_data["awaiting_confirm_payment"] = False
        return
    
    # Тикет поддержки
    if context.user_data.get("awaiting_ticket"):
        ticket_id = create_ticket(user_id, username, text)
        await update.message.reply_text(f"✅ **Тикет #{ticket_id} создан!**\n\nОтвет придёт сюда.", reply_markup=main_keyboard())
        
        for agent_id in SUPPORT_AGENTS:
            await context.bot.send_message(chat_id=agent_id, text=f"🆕 **Новый тикет #{ticket_id}**\n👤 @{username}\n📝 {text}\n\n/take {ticket_id}")
        
        context.user_data["awaiting_ticket"] = False
        return
    
    # Отзыв
    if context.user_data.get("awaiting_review"):
        try:
            parts = text.split(" ", 2)
            if len(parts) < 3:
                await update.message.reply_text("❌ Формат: `ID Оценка Текст`")
                context.user_data["awaiting_review"] = False
                return
            
            target_id = int(parts[0])
            rating = int(parts[1])
            comment = parts[2]
            
            if rating < 1 or rating > 5:
                await update.message.reply_text("❌ Оценка от 1 до 5!")
                context.user_data["awaiting_review"] = False
                return
            
            add_review(user_id, target_id, rating, comment)
            avg, count = get_seller_rating(target_id)
            
            await update.message.reply_text(f"✅ Отзыв оставлен!\n⭐ {rating}/5\n📊 Рейтинг: {avg}/5 ({count} отзывов)", reply_markup=main_keyboard())
            context.user_data["awaiting_review"] = False
        except:
            await update.message.reply_text("❌ Ошибка! Формат: `ID Оценка Текст`")
            context.user_data["awaiting_review"] = False
        return
    
    # Поиск отзывов
    if context.user_data.get("awaiting_find_reviews"):
        try:
            target_id = int(text)
            reviews = get_user_reviews(target_id)
            avg, count = get_seller_rating(target_id)
            
            if not reviews:
                await update.message.reply_text(f"📭 У пользователя {target_id} нет отзывов.", reply_markup=main_keyboard())
                context.user_data["awaiting_find_reviews"] = False
                return
            
            msg = f"⭐ **Отзывы о {target_id}**\n\n📊 Рейтинг: {avg}/5 ({count} отзывов)\n\n"
            for rev in reviews[:5]:
                msg += f"👤 от {rev[0]}\n⭐ {rev[1]}/5\n💬 {rev[2][:50]}\n📅 {rev[3]}\n\n"
            
            await update.message.reply_text(msg[:4000], reply_markup=main_keyboard())
            context.user_data["awaiting_find_reviews"] = False
        except:
            await update.message.reply_text("❌ Введи ID пользователя!")
            context.user_data["awaiting_find_reviews"] = False
        return
    
    # Назначение админа
    if context.user_data.get("awaiting_make_admin") and is_admin(user_id):
        try:
            target_id = int(text)
            make_admin(target_id)
            await update.message.reply_text(f"✅ Пользователь {target_id} назначен администратором!", reply_markup=main_keyboard())
            await context.bot.send_message(chat_id=target_id, text="👑 Вам выданы права администратора!")
            context.user_data["awaiting_make_admin"] = False
        except:
            await update.message.reply_text("❌ Ошибка!")
            context.user_data["awaiting_make_admin"] = False
        return
    
    # Бан
    if context.user_data.get("awaiting_ban") and is_admin(user_id):
        try:
            target_id = int(text)
            ban_user(target_id)
            await update.message.reply_text(f"✅ Пользователь {target_id} забанен!", reply_markup=main_keyboard())
            await context.bot.send_message(chat_id=target_id, text="🚫 Вы забанены!")
            context.user_data["awaiting_ban"] = False
        except:
            await update.message.reply_text("❌ Ошибка!")
            context.user_data["awaiting_ban"] = False
        return
    
    # Разбан
    if context.user_data.get("awaiting_unban") and is_admin(user_id):
        try:
            target_id = int(text)
            unban_user(target_id)
            await update.message.reply_text(f"✅ Пользователь {target_id} разбанен!", reply_markup=main_keyboard())
            await context.bot.send_message(chat_id=target_id, text="✅ Вы разбанены!")
            context.user_data["awaiting_unban"] = False
        except:
            await update.message.reply_text("❌ Ошибка!")
            context.user_data["awaiting_unban"] = False
        return
    
    # Команда /take
    if text.startswith("/take") and is_agent(user_id):
        try:
            parts = text.split()
            ticket_id = int(parts[1])
            take_ticket(ticket_id, user_id)
            await update.message.reply_text(f"✅ Тикет #{ticket_id} взят!\nОтветь: `/answer {ticket_id} <ответ>`", parse_mode="Markdown")
        except:
            await update.message.reply_text("❌ /take <id>")
        return
    
    # Команда /answer
    if text.startswith("/answer") and is_agent(user_id):
        try:
            parts = text.split(" ", 2)
            ticket_id = int(parts[1])
            answer = parts[2]
            
            close_ticket(ticket_id, answer)
            
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
            ticket_user = c.fetchone()
            conn.close()
            
            if ticket_user:
                await context.bot.send_message(chat_id=ticket_user[0], text=f"📬 **Ответ на тикет #{ticket_id}**\n\n{answer}")
            
            await update.message.reply_text(f"✅ Тикет #{ticket_id} закрыт.", reply_markup=main_keyboard())
        except:
            await update.message.reply_text("❌ /answer <id> <ответ>")
        return
    
    # Команда подтверждения от продавца
    if text.startswith("/confirm_delivery") and (is_admin(user_id) or user_id != ADMIN_ID):
        try:
            parts = text.split()
            deal_id = int(parts[1])
            deal = get_deal(deal_id)
            
            if not deal:
                await update.message.reply_text("❌ Сделка не найдена!")
                return
            
            if deal[3] != user_id:
                await update.message.reply_text("❌ Не ваша сделка!")
                return
            
            complete_deal(deal_id)
            
            buyer = get_user_by_id(deal[2])
            await context.bot.send_message(
                chat_id=deal[2],
                text=f"✅ **ТЕГ ПЕРЕДАН!**\nСделка #{deal_id} завершена!\n\nСпасибо за покупку!"
            )
            
            await update.message.reply_text(f"✅ Сделка #{deal_id} завершена! Тег передан покупателю.", reply_markup=main_keyboard())
        except:
            await update.message.reply_text("❌ /confirm_delivery <id_сделки>")
        return

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("take", handle_text))
    app.add_handler(CommandHandler("answer", handle_text))
    app.add_handler(CommandHandler("confirm_delivery", handle_text))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 TagShop Bot v3.0 запущен! Без ошибок.")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()