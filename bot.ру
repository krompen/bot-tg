    user_data = get_user(user.id)
    if user_data and user_data[6] == 1:
        await update.message.reply_text(
            f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[7]}\n\nОБРАТИТЕСЬ К АДМИНИСТРАТОРУ",
            reply_markup=back_keyboard()
        )
        return
    
    await update.message.reply_text(
        f"╔════════════════════════════════════════╗\n"
