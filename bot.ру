                await context.bot.send_message(
                    chat_id=agent_id[0],
                    text=f"🆕 НОВЫЙ ТИКЕТ #{ticket_id}\n👤 @{username}\n📝 {text}",
                    reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("✅ ВЗЯТЬ", callback_data=f"take_ticket_{ticket_id}")]])
                )
            except:
                pass
        
        await context.bot.send_message(chat_id=ADMIN_ID, text=f"🆕 НОВЫЙ ТИКЕТ #{ticket_id}\n👤 @{username}\n📝 {text}")
        context.user_data["awaiting_ticket"] = False
        return
    
    # Отзыв
    if context.user_data.get("awaiting_review"):
        try:
            parts = text.split(" ", 2)
            if len(parts) < 3:
                await update.message.reply_text("❌ ФОРМАТ: `ID ОЦЕНКА ТЕКСТ`")
                context.user_data["awaiting_review"] = False
                return
            
            target_id = int(parts[0])
            rating = int(parts[1])
            comment = parts[2]
            
            if rating < 1 or rating > 5:
                await update.message.reply_text("❌ ОЦЕНКА ОТ 1 ДО 5!")
                context.user_data["awaiting_review"] = False
                return
            
            add_review_user(user_id, target_id, rating, comment)
            avg, count = get_seller_rating(target_id)
            
            await update.message.reply_text(f"✅ ОТЗЫВ ОСТАВЛЕН!\n⭐ {rating}/5\n📊 РЕЙТИНГ: {avg}/5 ({count})", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_review"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА! ФОРМАТ: `ID ОЦЕНКА ТЕКСТ`")
            context.user_data["awaiting_review"] = False
        return
    
    # Поиск отзывов
    if context.user_data.get("awaiting_find_reviews"):
        try:
            target_id = int(text)
            reviews = get_user_reviews(target_id)
            avg, count = get_seller_rating(target_id)
            
