                text=f"💰 ПОКУПАТЕЛЬ ОПЛАТИЛ!\nСДЕЛКА #{deal_id}\n\nПЕРЕДАЙ ТЕГ И НАЖМИ КНОПКУ:",
                reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton("✅ Я ПЕРЕДАЛ ТЕГ", callback_data=f"seller_sent_{deal_id}")]
                ])
            )
            
            await update.message.reply_text(f"✅ УВЕДОМЛЕНИЕ ОТПРАВЛЕНО ПРОДАВЦУ!", reply_markup=main_keyboard(user_id))
            context.user_data["awaiting_confirm_payment"] = False
            
        except:
            await update.message.reply_text("❌ ВВЕДИ: `deal_123`")
            context.user_data["awaiting_confirm_payment"] = False
        return
    
    # Тикет
    if context.user_data.get("awaiting_ticket"):
        ticket_id = create_ticket(user_id, username, text)
        await update.message.reply_text(f"✅ ТИКЕТ #{ticket_id} СОЗДАН!\nОЖИДАЙТЕ ОТВЕТА", reply_markup=main_keyboard(user_id))
        
        for agent_id in get_all_agents():
