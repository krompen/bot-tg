async def deal_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if not context.args:
        await update.message.reply_text("❌ Используй: /deal_<id>\nПример: /deal_123")
        return
    try:
        deal_id = int(context.args[0])
    except:
        await update.message.reply_text("❌ Неверный ID сделки")
        return
    
    deal = get_deal(deal_id)
    if not deal:
        await update.message.reply_text("❌ Сделка не найдена")
        return
    
    user_id = update.effective_user.id
    if deal[1] == user_id:
        await update.message.reply_text("❌ Это твоя сделка, ты не можешь принять её сам")
        return
    
    if deal[8] != "waiting":
        await update.message.reply_text("❌ Эта сделка уже неактивна")
        return
    
    update_deal_status(deal_id, "active", user_id)
    await update.message.reply_text(f"✅ Ты принял сделку #{deal_id}!\n\n📤 Ты отдаёшь: {deal[4]} {deal[5]}\n📥 Ты получаешь: {deal[6]} {deal[7]}\n\nОжидайте выполнения условий.")
    await context.bot.send_message(chat_id=deal[1], text=f"✅ Пользователь @{update.effective_user.username} принял твою сделку #{deal_id}!")

