# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        full_name TEXT,
        registered_at TEXT,
        balance INTEGER DEFAULT 0,
        is_admin INTEGER DEFAULT 0,
        is_agent INTEGER DEFAULT 0,
        is_banned INTEGER DEFAULT 0
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS tags (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        category TEXT,
        price INTEGER,
        currency TEXT,
        seller_id INTEGER,
        buyer_id INTEGER DEFAULT NULL,
        description TEXT,
        status TEXT DEFAULT 'active',
        created_at TEXT,
        sold_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS tag_requests (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        seller_id INTEGER,
        tag_name TEXT,
        category TEXT,
        price INTEGER,
        currency TEXT,
        description TEXT,
        status TEXT DEFAULT 'pending',
        created_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS deals (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        tag_id INTEGER,
        buyer_id INTEGER,
        seller_id INTEGER,
        amount INTEGER,
        currency TEXT,
        status TEXT DEFAULT 'waiting_buyer',
        buyer_confirmed INTEGER DEFAULT 0,
        seller_confirmed INTEGER DEFAULT 0,
        created_at TEXT,
        completed_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS tickets (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        username TEXT,
        question TEXT,
        status TEXT DEFAULT 'open',
        taken_by INTEGER DEFAULT NULL,
        created_at TEXT,
        answer TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS reviews (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        reviewer_id INTEGER,
        reviewed_id INTEGER,
        rating INTEGER,
        comment TEXT,
        created_at TEXT
    )''')
    
    conn.commit()
    conn.close()

init_db()

