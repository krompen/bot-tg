async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    
    # Обработка реферальной ссылки
    referrer_id = None
    if context.args and context.args[0].startswith("ref_"):
        try:
            referrer_id = int(context.args[0].split("_")[1])
            if referrer_id == user.id:
                referrer_id = None
        except:
            pass
    
    add_user(user.id, user.username, user.full_name, referrer_id)
    
    await update.message.reply_text(
        f"👋 Добро пожаловать в **TagShop**, {user.first_name}!\n\n"
        f"🏷️ Здесь можно купить и продать красивые теги для Telegram.\n\n"
        f"📌 **Как пользоваться:**\n"
        f"• Нажми «🛒 Магазин тегов» — выбери категорию и купи тег\n"
        f"• Нажми «📤 Продать тег» — отправь заявку на продажу\n"
        f"• Нажми «🔗 Реферальная система» — получай 10% с покупок друзей\n\n"
        f"👑 Админ: @{ADMIN_USERNAME} {ADMIN_STATUS}\n\n"
        f"⬇️ Начинай прямо сейчас!",
        reply_markup=main_keyboard(),
        parse_mode="Markdown"
    )

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    user_id = query.from_user.id
    
    # Проверка бана
    user = get_user(user_id)
    if user and user[6] == 1 and data not in ["admin", "support"]:
        await query.edit_message_text("🚫 Вы забанены. Обратитесь к админу @{ADMIN_USERNAME}", reply_markup=back_keyboard())
        return
    
    # Главное меню
    if data == "back":
        await query.edit_message_text("Главное меню:", reply_markup=main_keyboard())
        return
    
    elif data == "shop":
        await query.edit_message_text("🛒 **Выбери категорию:**", reply_markup=categories_keyboard(), parse_mode="Markdown")
    
    elif data.startswith("cat_"):
        category = data.replace("cat_", "")
        tags = get_all_tags(category)
        if not tags:
            await query.edit_message_text("📭 В этой категории пока нет тегов.", reply_markup=back_keyboard())
            return
        
        text = f"🛒 **Теги в категории {category}:**\n\n"
        for tag in tags[:10]:
            text += f"🏷️ `{tag[1]}` | 💰 {tag[3]} {tag[4]}\n"
        text += "\nНажми на тег, чтобы купить:"
        
        keyboard = []
        for tag in tags[:10]:
            keyboard.append([InlineKeyboardButton(f"🏷️ {tag[1]} - {tag[3]} {tag[4]}", callback_data=f"buy_{tag[0]}")])
        keyboard.append([InlineKeyboardButton("🔙 Назад", callback_data="shop")])
        
        await query.edit_message_text(text, reply_markup=InlineKeyboardMarkup(keyboard), parse_mode="Markdown")
    
    elif data.startswith("buy_"):
        tag_id = int(data.split("_")[1])
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT id, name, price, currency, owner_id, history, proof FROM tags WHERE id = ? AND status = "active"', (tag_id,))
        tag = c.fetchone()
        conn.close()
        
        if not tag:
            await query.edit_message_text("❌ Тег уже продан или удалён.", reply_markup=back_keyboard())
            return
        
        context.user_data["buy_tag_id"] = tag_id
        context.user_data["buy_price"] = tag[2]
        context.user_data["buy_currency"] = tag[3]
        
        text = f"🏷️ **{tag[1]}**\n\n"
        text += f"💰 Цена: {tag[2]} {tag[3]}\n"
        text += f"📖 История: {tag[5] or 'Не указана'}\n"
        text += f"📸 Доказательства: {tag[6] or 'Нет'}\n\n"
        text += f"Для оплаты отправь {tag[2]} {tag[3]} на кошелёк @{ADMIN_USERNAME}\n"
        text += f"После оплаты отправь сюда чек командой /pay {tag_id}\n\n"
        text += f"✅ Проверка продавца: {'⭐' * 5}"
        
        await query.edit_message_text(text, reply_markup=back_keyboard(), parse_mode="Markdown")
    
    elif data == "my_orders":
        orders = get_user_orders(user_id)
        if not orders:
            await query.edit_message_text("📭 У вас пока нет покупок.", reply_markup=back_keyboard())
            return
        
        text = "📝 **Ваши покупки:**\n\n"
        for order in orders[:10]:
            status_emoji = {"pending": "⏳", "completed": "✅", "cancelled": "❌"}.get(order[4], "❓")
            text += f"{status_emoji} Заказ #{order[0]} | {order[2]} {order[3]}\n📅 {order[5]}\n\n"
        
        await query.edit_message_text(text, reply_markup=back_keyboard(), parse_mode="Markdown")
    
    elif data == "my_balance":
        user_data = get_user(user_id)
        if not user_data:
            await query.edit_message_text("❌ Ошибка.", reply_markup=back_keyboard())
            return
        
        text = f"💰 **Ваш баланс:** {user_data[4]} ⭐\n\n"
        text += f"👥 Реферальный баланс: {user_data[8]} ⭐\n"
        text += f"🔗 Ваша реф-ссылка: `https://t.me/{context.bot.username}?start=ref_{user_id}`\n\n"
        text += f"💸 Минимальный вывод: {MIN_WITHDRAW} ⭐"
        
        keyboard = [[InlineKeyboardButton("💸 Вывести средства", callback_data="withdraw")]]
        keyboard.append([InlineKeyboardButton("🔙 Назад", callback_data="back")])
        
        await query.edit_message_text(text, reply_markup=InlineKeyboardMarkup(keyboard), parse_mode="Markdown")
    
    elif data == "withdraw":
        user_data = get_user(user_id)
        if user_data[4] < MIN_WITHDRAW:
            await query.edit_message_text(f"❌ Минимальный вывод: {MIN_WITHDRAW} ⭐\nВаш баланс: {user_data[4]} ⭐", reply_markup=back_keyboard())
            return
        
        await query.edit_message_text("💸 **Вывод средств**\n\nВведи сумму и кошелёк в формате:\n`100 @username`", reply_markup=back_keyboard())
        context.user_data["awaiting_withdraw"] = True
    
    elif data == "sell_tag":
