def add_user(user_id, username, full_name):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT OR IGNORE INTO users (user_id, username, full_name, registered_at) VALUES (?, ?, ?, ?)',
                  (user_id, username, full_name, now))
        conn.commit()
        conn.close()
        return True
    except:
        return False

def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, full_name, registered_at, rating, reviews_count, total_deals FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def update_rating(user_id, rating):
    try:
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        user = get_user(user_id)
        if user:
            new_rating = (user[4] * user[5] + rating) / (user[5] + 1)
            c.execute('UPDATE users SET rating = ?, reviews_count = reviews_count + 1 WHERE user_id = ?', (new_rating, user_id))
            conn.commit()
        conn.close()
        return True
    except:
        return False

