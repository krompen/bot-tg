                context.user_data["awaiting_withdraw"] = False
                return
            
            if amount < MIN_WITHDRAW:
                await update.message.reply_text(f"❌ Минимальная сумма вывода: {MIN_WITHDRAW} ⭐", reply_markup=main_keyboard())
                context.user_data["awaiting_withdraw"] = False
                return
            
            create_withdrawal(user_id, amount, wallet)
            await update.message.reply_text(f"✅ Заявка на вывод {amount} ⭐ отправлена! Админ проверит и отправит средства на {wallet}", reply_markup=main_keyboard())
            context.user_data["awaiting_withdraw"] = False
        except:
            await update.message.reply_text("❌ Неверный формат. Введи: `сумма кошелёк`\nПример: `100 @username`", reply_markup=main_keyboard())
            context.user_data["awaiting_withdraw"] = False
        return
    
    # Отзыв
    if context.user_data.get("awaiting_review"):
        try:
            parts = text.split(" ", 1)
            seller_id = int(parts[0])
            comment = parts[1]
            
            # Парсим оценку из комментария
            rating = 5
            if "оценка" in comment.lower():
                for i in range(1, 6):
                    if str(i) in comment:
                        rating = i
                        break
            
            add_review(user_id, seller_id, 0, rating, comment)
            await update.message.reply_text(f"✅ Отзыв оставлен! Оценка: {rating}/5", reply_markup=main_keyboard())
            context.user_data["awaiting_review"] = False
        except:
            await update.message.reply_text("❌ Неверный формат. Введи: `ID_продавца Текст отзыва`", reply_markup=main_keyboard())
            context.user_data["awaiting_review"] = False
        return
    
    # Фейк-продажа
    if context.user_data.get("awaiting_fake_sale") and (user_id == ADMIN_ID or (user and user[5] == 1)):
        try:
            parts = text.split()
            tag_id = int(parts[0])
            amount = int(parts[1])
            
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('SELECT name, owner_id FROM tags WHERE id = ?', (tag_id,))
            tag = c.fetchone()
            conn.close()
            
            if not tag:
                await update.message.reply_text("❌ Тег не найден.", reply_markup=main_keyboard())
                return
            
            order_id = create_order(tag_id, ADMIN_ID, tag[1], amount, "stars")
            await update.message.reply_text(f"🎭 **Фейк-продажа создана!**\n\nЗаказ #{order_id}\nТег: {tag[0]}\nСумма: {amount} ⭐\n\nСтатус: ожидает оплаты", reply_markup=main_keyboard())
            context.user_data["awaiting_fake_sale"] = False
        except:
            await update.message.reply_text("❌ Неверный формат. Введи: `ID_тега сумма`", reply_markup=main_keyboard())
            context.user_data["awaiting_fake_sale"] = False
        return
    
    # Назначение админа
    if context.user_data.get("awaiting_make_admin") and user_id == ADMIN_ID:
        try:
            target_id = int(text)
            make_admin(target_id)
            await update.message.reply_text(f"✅ Пользователь {target_id} назначен администратором!", reply_markup=main_keyboard())
            await context.bot.send_message(chat_id=target_id, text="👑 Вам выданы права администратора!")
            context.user_data["awaiting_make_admin"] = False
        except:
            await update.message.reply_text("❌ Ошибка. Введи корректный ID пользователя.", reply_markup=main_keyboard())
            context.user_data["awaiting_make_admin"] = False
        return
    
    # Бан
    if context.user_data.get("awaiting_ban") and user_id == ADMIN_ID:
        try:
            target_id = int(text)
            ban_user(target_id)
            await update.message.reply_text(f"✅ Пользователь {target_id} забанен!", reply_markup=main_keyboard())
            await context.bot.send_message(chat_id=target_id, text="🚫 Вы были забанены в боте!")
            context.user_data["awaiting_ban"] = False
        except:
            await update.message.reply_text("❌ Ошибка. Введи корректный ID пользователя.", reply_markup=main_keyboard())
            context.user_data["awaiting_ban"] = False
        return
    
    # Разбан
    if context.user_data.get("awaiting_unban") and user_id == ADMIN_ID:
        try:
            target_id = int(text)
            unban_user(target_id)
            await update.message.reply_text(f"✅ Пользователь {target_id} разбанен!", reply_markup=main_keyboard())
            await context.bot.send_message(chat_id=target_id, text="✅ Вы были разбанены в боте!")
            context.user_data["awaiting_unban"] = False
        except:
            await update.message.reply_text("❌ Ошибка. Введи корректный ID пользователя.", reply_markup=main_keyboard())
            context.user_data["awaiting_unban"] = False
        return
    
    # Закрытие тикета с ответом
    if context.user_data.get("awaiting_close_ticket"):
        ticket_id = context.user_data["awaiting_close_ticket"]
        close_ticket(ticket_id, text)
        
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
        ticket_user = c.fetchone()
        conn.close()
        
        if ticket_user:
            await context.bot.send_message(chat_id=ticket_user[0], text=f"📬 **Ответ на тикет #{ticket_id}**\n\n{text}")
        
        await update.message.reply_text(f"✅ Тикет #{ticket_id} закрыт с ответом.", reply_markup=main_keyboard())
        context.user_data["awaiting_close_ticket"] = False
        return
    
    # Команда оплаты
    if text.startswith("/pay"):
        try:
            parts = text.split()
            tag_id = int(parts[1])
            
            await update.message.reply_text(
                f"💰 Оплата тега #{tag_id}\n\n"
                f"Отправь чек оплаты на @{ADMIN_USERNAME}\n"
                f"Или переведи звёзды через Telegram Stars\n\n"
                f"После оплаты напиши /confirm {tag_id}",
                reply_markup=main_keyboard()
            )
        except:
            await update.message.reply_text("❌ Используй: /pay <id_тега>")
        return
    
    # Подтверждение оплаты
    if text.startswith("/confirm"):
        try:
            parts = text.split()
            tag_id = int(parts[1])
            
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=f"💰 **Запрос на подтверждение оплаты**\n👤 @{username}\n🏷️ Тег #{tag_id}\n\nПроверь оплату и подтверди командой:\n/complete {tag_id} {user_id}"
            )
            await update.message.reply_text("✅ Запрос отправлен админу. Ожидайте подтверждения.", reply_markup=main_keyboard())
        except:
            await update.message.reply_text("❌ Используй: /confirm <id_тега>")
        return
    
    # Завершение продажи (админ)
    if text.startswith("/complete") and (user_id == ADMIN_ID or (user and user[5] == 1)):
        try:
            parts = text.split()
            tag_id = int(parts[1])
            buyer_id = int(parts[2])
            
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('SELECT name, owner_id FROM tags WHERE id = ?', (tag_id,))
            tag = c.fetchone()
            
            if tag:
                # Обновляем владельца тега
                c.execute('UPDATE tags SET owner_id = ?, status = "sold" WHERE id = ?', (buyer_id, tag_id))
                # Завершаем заказ
                c.execute('UPDATE orders SET status = "completed", completed_at = ? WHERE tag_id = ? AND buyer_id = ?', 
                         (datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S"), tag_id, buyer_id))
                conn.commit()
                
                # Начисляем реферальный бонус
                buyer = get_user(buyer_id)
                if buyer and buyer[7]:
                    ref_bonus = int(tag[2] * REF_PERCENT / 100)
                    update_balance(buyer[7], ref_bonus)
                    add_transaction(buyer[7], ref_bonus, "ref_bonus", f"Бонус за покупку реферала")
                
                await update.message.reply_text(f"✅ Продажа тега {tag[0]} подтверждена!\nПокупатель: {buyer_id}")
                await context.bot.send_message(chat_id=buyer_id, text=f"✅ Ваша покупка тега {tag[0]} подтверждена!\n\nТег ваш! Спасибо за покупку!")
            
            conn.close()
        except:
            await update.message.reply_text("❌ Используй: /complete <id_тега> <id_покупателя>")
        return
    
    # Ответ на тикет через команду
    if text.startswith("/answer_ticket") and (user_id == ADMIN_ID or (user and user[5] == 1)):
        try:
            parts = text.split(" ", 2)
            ticket_id = int(parts[1])
            answer = parts[2]
            
            close_ticket(ticket_id, answer)
            
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
            ticket_user = c.fetchone()
            conn.close()
            
            if ticket_user:
                await context.bot.send_message(chat_id=ticket_user[0], text=f"📬 **Ответ на тикет #{ticket_id}**\n\n{answer}")
            
            await update.message.reply_text(f"✅ Тикет #{ticket_id} закрыт с ответом.", reply_markup=main_keyboard())
        except:
            await update.message.reply_text("❌ Используй: /answer_ticket <id_тикета> <ответ>")
        return
    
    # Если ничего не подошло
    await update.message.reply_text("Используй кнопки меню для навигации.", reply_markup=main_keyboard())

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("pay", handle_text))
    app.add_handler(CommandHandler("confirm", handle_text))
    app.add_handler(CommandHandler("complete", handle_text))
    app.add_handler(CommandHandler("answer_ticket", handle_text))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 TagShop Bot запущен!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()