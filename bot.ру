            conn.close()
            
            if ticket_user:
                await context.bot.send_message(
                    chat_id=ticket_user[0],
                    text=f"📬 **ОТВЕТ НА ТИКЕТ #{ticket_id}**\n\n{answer}\n\n— @{username}"
                )
            
            await update.message.reply_text(f"✅ ТИКЕТ #{ticket_id} ЗАКРЫТ.", reply_markup=main_keyboard(show_admin=is_admin(user_id)))
        except:
            await update.message.reply_text("❌ /answer <ID_ТИКЕТА> <ОТВЕТ>")
        return
    
    # Если ничего не подошло
    await update.message.reply_text(
        "❓ **НЕ ПОНЯЛ КОМАНДУ.**\n\n"
        "ИСПОЛЬЗУЙ КНОПКИ МЕНЮ ДЛЯ НАВИГАЦИИ.",
        reply_markup=main_keyboard(show_admin=is_admin(user_id))
    )

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("answer", handle_text))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 TAGSHOP BOT v4.0 ЗАПУЩЕН! БЕЗ ОШИБОК!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()