def get_tag(tag_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT id, name, price, currency, seller_id, description, proof, created_at, views FROM tags WHERE id = ? AND status = "active"', (tag_id,))
    tag = c.fetchone()
    if tag:
        c.execute('UPDATE tags SET views = views + 1 WHERE id = ?', (tag_id,))
        conn.commit()
    conn.close()
    return tag

