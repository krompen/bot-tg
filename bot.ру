# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        full_name TEXT,
        registered_at TEXT,
        is_vip INTEGER DEFAULT 0,
        vip_until TEXT DEFAULT NULL,
        daily_messages INTEGER DEFAULT 0,
        last_message_date TEXT DEFAULT NULL
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS conversations (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        role TEXT,
        content TEXT,
        created_at TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS vip_payments (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        amount INTEGER,
        status TEXT DEFAULT 'pending',
        created_at TEXT,
        confirmed_at TEXT
    )''')
    conn.commit()
    conn.close()

init_db()

# ========== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ==========
def add_user(user_id, username, full_name):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO users (user_id, username, full_name, registered_at) VALUES (?, ?, ?, ?)',
              (user_id, username, full_name, now))
    conn.commit()
    conn.close()

def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, full_name, registered_at, is_vip, vip_until, daily_messages, last_message_date FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def update_daily_messages(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    today = datetime.datetime.now().strftime("%Y-%m-%d")
    c.execute('SELECT last_message_date, daily_messages FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    
    if not row:
        conn.close()
        return
    
    last_date, count = row
    if last_date != today:
        count = 1
    else:
        count += 1
    
    c.execute('UPDATE users SET daily_messages = ?, last_message_date = ? WHERE user_id = ?', (count, today, user_id))
    conn.commit()
    conn.close()
    return count

def can_send_message(user_id):
    user = get_user(user_id)
    if not user:
        return True, 0
    
    is_vip = user[4]
    today = datetime.datetime.now().strftime("%Y-%m-%d")
    last_date = user[7] or ""
    daily_count = user[6] or 0
    
    if last_date != today:
        return True, 0
    
    limit = VIP_DAILY_LIMIT if is_vip else FREE_DAILY_LIMIT
    if daily_count >= limit:
        return False, limit
    
    return True, limit

def save_message(user_id, role, content):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO conversations (user_id, role, content, created_at) VALUES (?, ?, ?, ?)',
              (user_id, role, content, now))
    conn.commit()
    conn.close()

def get_conversation_history(user_id, limit=10):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT role, content FROM conversations WHERE user_id = ? ORDER BY id DESC LIMIT ?', (user_id, limit))
    rows = c.fetchall()
    conn.close()
    return list(reversed(rows))  # от старых к новым

def set_vip(user_id, days=30):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    until = (datetime.datetime.now() + datetime.timedelta(days=days)).strftime("%Y-%m-%d %H:%M:%S")
    c.execute('UPDATE users SET is_vip = 1, vip_until = ? WHERE user_id = ?', (until, user_id))
    conn.commit()
    conn.close()

def create_vip_payment(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO vip_payments (user_id, amount, created_at) VALUES (?, ?, ?)', (user_id, VIP_PRICE, now))
    payment_id = c.lastrowid
    conn.commit()
    conn.close()
    return payment_id

def confirm_vip_payment(payment_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('SELECT user_id FROM vip_payments WHERE id = ?', (payment_id,))
    row = c.fetchone()
    if row:
        c.execute('UPDATE vip_payments SET status = "confirmed", confirmed_at = ? WHERE id = ?', (now, payment_id))
        set_vip(row[0])
    conn.commit()
    conn.close()

