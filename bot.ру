        await update.message.reply_text(
            f"*Старик устало трёт переносицу, откладывает очки*\n\n"
            f"— Мил человек, сегодня я уже выдохся. Лимит на сегодня — {limit} сообщений. Приходи завтра.\n\n"
            f"*Тушит сигарету, закутывается в плед*\n\n"
            f"{'А вообще, знаешь... VIP-доступ даёт 100 сообщений в день. Задумайся.' if not is_vip else ''}",
            reply_markup=main_keyboard(),
            parse_mode="Markdown"
        )
        return
    
    # Сохраняем сообщение пользователя
    save_message(user_id, "user", user_message)
    update_daily_messages(user_id)
    
    # Отправляем статус "печатает"
    await context.bot.send_chat_action(chat_id=update.effective_chat.id, action="typing")
    
    # Получаем ответ от рассказчика
    response = await get_philosopher_response(user_id, user_message)
    
    # Сохраняем ответ
    save_message(user_id, "assistant", response)
    
    # Отправляем ответ
    await update.message.reply_text(response, parse_mode="Markdown")

async def stop(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data["in_chat"] = False
    await update.message.reply_text(
        "*Старик тушит сигарету, встаёт, смотрит в окно*\n\n"
        "— Ну бывай, мил человек. Дверь не закрыта, захочешь поговорить — приходи.\n\n"
        "*Поправляет пиджак, садится обратно*\n\n"
        "Жду тебя.",
        reply_markup=main_keyboard(),
        parse_mode="Markdown"
    )

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("stop", stop))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🎭 Старый курящий рассказчик запущен...")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()