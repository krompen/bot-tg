async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    
    if context.user_data.get("awaiting_give"):
        try:
            parts = text.split()
            amount = parts[0]
            currency = parts[1]
            context.user_data["give_amount"] = amount
            context.user_data["give_currency"] = currency
            context.user_data["awaiting_give"] = False
            context.user_data["awaiting_receive"] = True
            await update.message.reply_text(f"📥 Что ты получаешь? (сумму и валюту через пробел)\nПример: `50 ton`")
        except:
            await update.message.reply_text("❌ Неверный формат. Введи сумму и валюту через пробел.\nПример: `100 stars`")
    
    elif context.user_data.get("awaiting_receive"):
        try:
            parts = text.split()
            amount = parts[0]
            currency = parts[1]
            deal_type = context.user_data.get("deal_type")
            give_amount = context.user_data.get("give_amount")
            give_currency = context.user_data.get("give_currency")
            deal_id = create_deal(user_id, deal_type, give_amount, give_currency, amount, currency)
            if deal_id:
                await update.message.reply_text(
                    f"✅ Сделка #{deal_id} создана!\n\n"
                    f"📤 Ты отдаёшь: {give_amount} {give_currency}\n"
                    f"📥 Ты получаешь: {amount} {currency}\n\n"
                    f"🔗 **Отправь партнёру эту ссылку:**\n`/deal_{deal_id}`\n\n"
                    f"Партнёр должен ввести эту команду, чтобы принять сделку.",
                    reply_markup=main_keyboard()
                )
            else:
                await update.message.reply_text("❌ Ошибка при создании сделки.")
            context.user_data["awaiting_receive"] = False
            context.user_data["deal_type"] = None
            context.user_data["give_amount"] = None
            context.user_data["give_currency"] = None
        except:
            await update.message.reply_text("❌ Неверный формат.")
    
    elif context.user_data.get("awaiting_broadcast") and user_id == ADMIN_ID:
        users = get_all_users()
        sent = 0
        for user in users:
            try:
                await context.bot.send_message(chat_id=user[0], text=f"📢 **РАССЫЛКА ОТ АДМИНА**\n\n{text}")
                sent += 1
            except:
                pass
        await update.message.reply_text(f"✅ Рассылка отправлена {sent} пользователям.")
        context.user_data["awaiting_broadcast"] = False
    
    elif context.user_data.get("awaiting_ticket"):
        ticket_id = create_ticket(user_id, update.effective_user.username or str(user_id), text)
        if ticket_id:
            await update.message.reply_text(f"✅ Сообщение отправлено! Номер тикета: #{ticket_id}\nАдмин ответит в ближайшее время.")
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=f"🆕 **Новый тикет #{ticket_id}**\n👤 @{update.effective_user.username} (ID: {user_id})\n📝 {text}\n\n💡 /take_ticket {ticket_id}"
            )
        else:
            await update.message.reply_text("❌ Ошибка при создании тикета.")
        context.user_data["awaiting_ticket"] = False
    
    elif context.user_data.get("awaiting_chat_message"):
        deal_id = context.user_data.get("chat_deal_id")
        if deal_id:
            add_chat_message(deal_id, user_id, update.effective_user.username or str(user_id), text)
            await update.message.reply_text("✅ Сообщение отправлено в чат сделки.")
            deal = get_deal(deal_id)
            if deal:
                other_id = deal[2] if deal[1] == user_id else deal[1]
                if other_id:
                    try:
                        await context.bot.send_message(chat_id=other_id, text=f"💬 Новое сообщение в чате сделки #{deal_id}\n👤 @{update.effective_user.username}: {text[:50]}...")
                    except:
                        pass
        context.user_data["awaiting_chat_message"] = False
    
    elif context.user_data.get("awaiting_add_item") and user_id == ADMIN_ID:
        try:
            parts = text.split("|")
            name = parts[0].strip()
            description = parts[1].strip()
            price = int(parts[2].strip())
            currency = parts[3].strip()
            add_shop_item(ADMIN_ID, name, description, price, currency)
            await update.message.reply_text(f"✅ Товар «{name}» добавлен в магазин!")
        except:
            await update.message.reply_text("❌ Неверный формат. Используй: `название | описание | цена | валюта`")
        context.user_data["awaiting_add_item"] = False
    
    elif context.user_data.get("awaiting_remove_item") and user_id == ADMIN_ID:
        try:
            item_id = int(text)
            remove_shop_item(item_id)
            await update.message.reply_text(f"✅ Товар #{item_id} удалён из магазина.")
        except:
            await update.message.reply_text("❌ Неверный ID товара.")
        context.user_data["awaiting_remove_item"] = False
    
    elif context.user_data.get("awaiting_review_comment"):
        deal_id, partner_id, rating = context.user_data["awaiting_review_comment"]
        comment = text if text != "-" else ""
        add_review(user_id, partner_id, deal_id, rating, comment)
        await update.message.reply_text(f"✅ Спасибо за отзыв! Рейтинг пользователя обновлён.")
        context.user_data["awaiting_review_comment"] = None

async def take_ticket_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if not context.args:
        await update.message.reply_text("❌ /take_ticket <ticket_id>")
        return
    try:
        ticket_id = int(context.args[0])
        take_ticket(ticket_id, ADMIN_ID)
        await update.message.reply_text(f"✅ Тикет #{ticket_id} взят в работу.")
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
        row = c.fetchone()
        conn.close()
        if row:
            await context.bot.send_message(chat_id=row[0], text=f"🟢 Админ @{ADMIN_USERNAME} взял ваш тикет #{ticket_id} в работу!")
    except:
        await update.message.reply_text("❌ Ошибка.")

async def close_ticket_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    if len(context.args) < 2:
        await update.message.reply_text("❌ /close_ticket <ticket_id> <ответ>")
        return
    try:
        ticket_id = int(context.args[0])
        answer = " ".join(context.args[1:])
        close_ticket(ticket_id, answer)
        await update.message.reply_text(f"✅ Тикет #{ticket_id} закрыт.")
        conn = sqlite3.connect(DB_NAME, timeout=10)
        c = conn.cursor()
        c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
        row = c.fetchone()
        conn.close()
        if row:
            await context.bot.send_message(chat_id=row[0], text=f"📬 **Ответ на тикет #{ticket_id}**\n\n✅ {answer}")
    except:
        await update.message.reply_text("❌ Ошибка.")

def get_all_users():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    users = c.execute('SELECT user_id FROM users').fetchall()
    conn.close()
    return users

async def broadcast_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("⛔ Нет прав.")
        return
    text = " ".join(context.args)
    if not text:
        await update.message.reply_text("❌ /broadcast <текст>")
        return
    users = get_all_users()
    sent = 0
    for user in users:
        try:
            await context.bot.send_message(chat_id=user[0], text=f"📢 **РАССЫЛКА ОТ АДМИНА**\n\n{text}")
            sent += 1
        except:
            pass
    await update.message.reply_text(f"✅ Рассылка отправлена {sent} пользователям.")

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("broadcast", broadcast_command))
    app.add_handler(CommandHandler("take_ticket", take_ticket_command))
    app.add_handler(CommandHandler("close_ticket", close_ticket_command))
    app.add_handler(MessageHandler(filters.Regex(r'^/deal_\d+$'), deal_command))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("✅ Ciwige Garant Bot запущен")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()