# ========== ВРЕМЯ МСК ==========
def get_time():
    # Москва UTC+3
    return (datetime.datetime.utcnow() + datetime.timedelta(hours=3)).strftime("%H:%M:%S")

def get_full_time():
    return (datetime.datetime.utcnow() + datetime.timedelta(hours=3)).strftime("%Y-%m-%d %H:%M:%S")

# ========== БАЗА ДАННЫХ ==========
DB_NAME = "database.db"

def init_db():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        first_name TEXT,
        joined_date TEXT,
        last_active TEXT,
        is_banned INTEGER DEFAULT 0
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS logs (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        action TEXT,
        time TEXT
    )''')
    c.execute('''CREATE TABLE IF NOT EXISTS templates (
        keyword TEXT PRIMARY KEY,
        response TEXT
    )''')
    conn.commit()
    conn.close()

def add_user(user_id, username, first_name):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    now = get_full_time()
    c.execute('''INSERT OR IGNORE INTO users (user_id, username, first_name, joined_date, last_active)
                 VALUES (?, ?, ?, ?, ?)''', (user_id, username, first_name, now, now))
    conn.commit()
    conn.close()

def update_activity(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('UPDATE users SET last_active = ? WHERE user_id = ?', (get_full_time(), user_id))
    conn.commit()
    conn.close()

def log_action(user_id, action):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('INSERT INTO logs (user_id, action, time) VALUES (?, ?, ?)', (user_id, action, get_full_time()))
    conn.commit()
    conn.close()

def is_banned(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT is_banned FROM users WHERE user_id = ?', (user_id,))
    row = c.fetchone()
    conn.close()
    return row and row[0] == 1

def ban_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('UPDATE users SET is_banned = 1 WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()
    log_action(ADMIN_ID, f"Забанил {user_id}")

def unban_user(user_id):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('UPDATE users SET is_banned = 0 WHERE user_id = ?', (user_id,))
    conn.commit()
    conn.close()
    log_action(ADMIN_ID, f"Разбанил {user_id}")

def get_all_users():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT user_id, username, first_name, joined_date, last_active, is_banned FROM users')
    users = c.fetchall()
    conn.close()
    return users

def get_template(word):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT response FROM templates WHERE keyword = ?', (word.lower(),))
    row = c.fetchone()
    conn.close()
    return row[0] if row else None

def save_template(word, response):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('INSERT OR REPLACE INTO templates (keyword, response) VALUES (?, ?)', (word.lower(), response))
    conn.commit()
    conn.close()
    log_action(ADMIN_ID, f"Добавил шаблон: {word}")

def delete_template(word):
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('DELETE FROM templates WHERE keyword = ?', (word.lower(),))
    conn.commit()
    conn.close()
    log_action(ADMIN_ID, f"Удалил шаблон: {word}")

def get_all_templates():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT keyword, response FROM templates')
    rows = c.fetchall()
    conn.close()
    return rows

# ========== КЛАВИАТУРЫ ==========
def user_keyboard():
    return ReplyKeyboardMarkup([["🕒 Время", "📝 Совет"], ["❓ Помощь"]], resize_keyboard=True)

def admin_keyboard():
    return ReplyKeyboardMarkup([
        ["📊 Статистика", "📢 Рассылка"],
        ["👥 Пользователи", "🔨 Бан/Разбан"],
        ["📝 Шаблоны", "📜 Логи"],
        ["🔙 Назад"]
    ], resize_keyboard=True)

# ========== ОБЫЧНЫЕ КОМАНДЫ ==========
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user = update.effective_user
    if is_banned(user.id):
        await update.message.reply_text("⛔ Ты в бане.")
        return
    add_user(user.id, user.username, user.first_name)
    update_activity(user.id)
    log_action(user.id, "/start")
    text = f"🤝 Привет, {user.first_name}!\n/time — время\n/advice — совет\n/help — помощь"
    if user.id == ADMIN_ID:
        text += "\n\n👑 Админ-панель: /admin"
    await update.message.reply_text(text, reply_markup=user_keyboard())

async def help_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if is_banned(update.effective_user.id):
        return
    await update.message.reply_text("/start — привет\n/time — время\n/advice — совет")

async def time_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if is_banned(update.effective_user.id):
        return
    log_action(update.effective_user.id, "/time")
    await update.message.reply_text(f"🕒 {get_time()} МСК")

async def advice_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if is_banned(update.effective_user.id):
        return
    advices = ["Выпей воды 💧", "Сделай глубокий вдох 🌬️", "Отдохни 5 минут ☕", "Ты молодец! 🔥"]
    await update.message.reply_text(random.choice(advices))

# ========== АДМИН-КОМАНДЫ ==========
async def admin_panel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        await update.message.reply_text("Нет прав.")
        return
    await update.message.reply_text("👑 Админ-панель", reply_markup=admin_keyboard())

async def admin_stats(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    users = get_all_users()
    total = len(users)
    banned = sum(1 for u in users if u[5] == 1)
    await update.message.reply_text(f"📊 Статистика:\n👥 Всего: {total}\n🔨 Забанено: {banned}\n✅ Активных: {total - banned}")

async def admin_users(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    users = get_all_users()
    if not users:
        await update.message.reply_text("Нет пользователей.")
        return
    text = "👥 Пользователи:\n\n"
    for u in users:
        status = "🔨" if u[5] == 1 else "✅"
        text += f"{status} {u[2]} (@{u[1]}) — ID: {u[0]}\n"
    await update.message.reply_text(text[:4000])

async def admin_ban_menu(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    await update.message.reply_text("Введи ID пользователя для бана/разбана:")
    context.user_data["waiting_ban"] = True

async def admin_broadcast_menu(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    await update.message.reply_text("Введи текст для рассылки:")
    context.user_data["waiting_broadcast"] = True

async def admin_templates(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    templates = get_all_templates()
    if not templates:
        await update.message.reply_text("Шаблонов нет.\n/add_template слово | ответ")
    else:
        text = "📝 Шаблоны:\n"
        for kw, resp in templates:
            text += f"• {kw} → {resp[:40]}\n"
        await update.message.reply_text(text[:4000])

async def admin_logs(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute('SELECT user_id, action, time FROM logs ORDER BY id DESC LIMIT 30')
    logs = c.fetchall()
    conn.close()
    if not logs:
        await update.message.reply_text("Логов нет.")
        return
    text = "📜 Последние логи:\n\n"
    for log in logs:
        text += f"{log[2]} — {log[1]} (ID: {log[0]})\n"
    await update.message.reply_text(text[:4000])

async def add_template_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    try:
        args = " ".join(context.args).split("|")
        word = args[0].strip()
        response = args[1].strip()
        save_template(word, response)
        await update.message.reply_text(f"✅ Шаблон '{word}' добавлен.")
    except:
        await update.message.reply_text("❌ Используй: /add_template слово | ответ")

async def del_template_cmd(update: Update, context: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id != ADMIN_ID:
        return
    if not context.args:
        await update.message.reply_text("❌ /del_template слово")
        return
    word = context.args[0]
    delete_template(word)
    await update.message.reply_text(f"✅ Шаблон '{word}' удалён.")

# ========== ОБРАБОТЧИКИ СООБЩЕНИЙ ==========
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if is_banned(user_id):
        await update.message.reply_text("⛔ Ты в бане.")
        return
    update_activity(user_id)
    text = update.message.text

    # Проверка шаблона
    template = get_template(text)
    if template:
        await update.message.reply_text(template)
        return

    # Кнопки пользователя
    if text == "🕒 Время":
        await time_cmd(update, context)
    elif text == "📝 Совет":
        await advice_cmd(update, context)
    elif text == "❓ Помощь":
        await help_cmd(update, context)
    elif text == "🔙 Назад" and user_id == ADMIN_ID:
        await admin_panel(update, context)
    # Админ-кнопки
    elif user_id == ADMIN_ID:
        if text == "📊 Статистика":
            await admin_stats(update, context)
        elif text == "📢 Рассылка":
            await admin_broadcast_menu(update, context)
        elif text == "👥 Пользователи":
            await admin_users(update, context)
        elif text == "🔨 Бан/Разбан":
            await admin_ban_menu(update, context)
        elif text == "📝 Шаблоны":
            await admin_templates(update, context)
        elif text == "📜 Логи":
            await admin_logs(update, context)
        elif text == "👑 Админ-панель":
            await admin_panel(update, context)
        else:
            await update.message.reply_text("❓ Не понял. /help")
    else:
        await update.message.reply_text("❓ Не понял. /help")

async def handle_admin_input(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    if user_id != ADMIN_ID:
        return

    # Обработка бана
    if context.user_data.get("waiting_ban"):
        try:
            target_id = int(update.message.text.strip())
            if is_banned(target_id):
                unban_user(target_id)
                await update.message.reply_text(f"✅ Пользователь {target_id} разбанен.")
            else:
                ban_user(target_id)
                await update.message.reply_text(f"🔨 Пользователь {target_id} забанен.")
        except:
            await update.message.reply_text("❌ Введи числовой ID.")
        context.user_data["waiting_ban"] = False
        await admin_panel(update, context)
        return

    # Обработка рассылки
    if context.user_data.get("waiting_broadcast"):
        msg = update.message.text
        users = get_all_users()
        sent = 0
        for u in users:
            if u[5] == 0:
                try:
                    await context.bot.send_message(chat_id=u[0], text=f"📢 РАССЫЛКА:\n\n{msg}")
                    sent += 1
                except:
                    pass
        await update.message.reply_text(f"✅ Рассылка отправлена {sent} пользователям.")
        log_action(ADMIN_ID, f"Рассылка: {msg[:50]}")
        context.user_data["waiting_broadcast"] = False
        await admin_panel(update, context)
        return

# ========== ЗАПУСК ==========
def main():
    init_db()
    app = Application.builder().token(TOKEN).build()

    # Команды
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("help", help_cmd))
    app.add_handler(CommandHandler("time", time_cmd))
    app.add_handler(CommandHandler("advice", advice_cmd))
    app.add_handler(CommandHandler("admin", admin_panel))
    app.add_handler(CommandHandler("add_template", add_template_cmd))
    app.add_handler(CommandHandler("del_template", del_template_cmd))

    # Обработка текста (кнопки и админ-ввод)
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(MessageHandler(filters.TEXT & filters.Chat(ADMIN_ID), handle_admin_input))

    print("✅ Бот запущен с админкой, баном, рассылкой, шаблонами, логами, МСК")
    app.run_polling()

if __name__ == "__main__":
    main()