        except:
            await update.message.reply_text("❌ /answer <ID> <ОТВЕТ>")
        return
    
    await update.message.reply_text("❓ НЕ ПОНЯЛ КОМАНДУ.\n\nИСПОЛЬЗУЙ КНОПКИ МЕНЮ.", reply_markup=main_keyboard(user_id))

# ========== ПЛАТЕЖИ ==========
async def pre_checkout_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.pre_checkout_query
    await query.answer(ok=True)

async def successful_payment_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    payload = update.message.successful_payment.invoice_payload
    
    if payload.startswith("gift_"):
        parts = payload.split("_")
        gift_id = parts[1]
        desc_type = parts[2] if len(parts) > 2 else "free"
        
        gift = next((g for g in GIFTS if g["id"] == gift_id), None)
        if not gift:
            return
        
        if desc_type == "free":
            description = FREE_DESCRIPTION
            total_price = gift['price']
        elif desc_type == "template":
            template_index = int(parts[3]) if len(parts) > 3 else 0
            username = update.effective_user.username or str(user_id)
            description = TEMPLATES[template_index].format(username=username)
            total_price = gift['price'] + 5
        elif desc_type == "custom":
            description = context.user_data.get("custom_gift_text", FREE_DESCRIPTION)
            total_price = gift['price'] + 10
        else:
            description = FREE_DESCRIPTION
            total_price = gift['price']
        
        save_gift_order(user_id, gift_id, desc_type, description, total_price)
        
        await update.message.reply_text(
            f"✅ **ОПЛАТА ПРОШЛА УСПЕШНО!**\n\n"
            f"🎁 {gift['name']}\n"
            f"📝 Описание: {description}\n\n"
            f"СПАСИБО ЗА ПОКУПКУ! 🎉",
            reply_markup=main_keyboard(user_id),
            parse_mode="Markdown"
        )
        
        await context.bot.send_message(
            chat_id=ADMIN_ID,
            text=f"🎁 НОВАЯ ПОКУПКА ПОДАРКА\n👤 @{update.effective_user.username}\n🎁 {gift['name']}\n💰 {total_price}⭐\n📝 {description[:50]}"
        )

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("answer", handle_text))
    app.add_handler(PreCheckoutQueryHandler(pre_checkout_handler))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, successful_payment_handler))
    app.add_handler(MessageHandler(filters.PHOTO | filters.ATTACHMENT | filters.TEXT & ~filters.COMMAND, handle_text))
    app.add_handler(CallbackQueryHandler(button_handler))
    
    print("🚀 TAGSHOP BOT v7.0 ЗАПУЩЕН! МАГАЗИН ПОДАРКОВ РАБОТАЕТ!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()