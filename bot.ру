    tags = c.fetchall()
    conn.close()
    return tags

def get_tag(tag_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT id, name, price, currency, seller_id, description, proof, created_at, views FROM tags WHERE id = ? AND status = "active"', (tag_id,))
    tag = c.fetchone()
    if tag:
        c.execute('UPDATE tags SET views = views + 1 WHERE id = ?', (tag_id,))
        conn.commit()
    conn.close()
    return tag

def create_tag_request(seller_id, tag_name, price, currency, description, proof):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO tag_requests (seller_id, tag_name, price, currency, description, proof, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
              (seller_id, tag_name, price, currency, description, proof, now))
    req_id = c.lastrowid
    conn.commit()
    conn.close()
    return req_id

def approve_tag_request(req_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT seller_id, tag_name, price, currency, description, proof FROM tag_requests WHERE id = ?', (req_id,))
    req = c.fetchone()
    if req:
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO tags (name, price, currency, seller_id, description, proof, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
                  (req[1], req[2], req[3], req[0], req[4], req[5], now))
        c.execute('UPDATE tag_requests SET status = "approved" WHERE id = ?', (req_id,))
    conn.commit()
    conn.close()

