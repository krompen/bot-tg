# ========== БАЗА ДАННЫХ ==========
def init_db():
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    
    c.execute('''CREATE TABLE IF NOT EXISTS users (
        user_id INTEGER PRIMARY KEY,
        username TEXT,
        registered_at TEXT
    )''')
    
    c.execute('''CREATE TABLE IF NOT EXISTS passwords (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        password TEXT,
        category TEXT,
        service TEXT,
        created_at TEXT
    )''')
    
    conn.commit()
    conn.close()

init_db()

# ========== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ==========
def add_user(user_id, username):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO users (user_id, username, registered_at) VALUES (?, ?, ?)', (user_id, username, now))
    conn.commit()
    conn.close()

def save_password(user_id, password, category, service):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO passwords (user_id, password, category, service, created_at) VALUES (?, ?, ?, ?, ?)',
              (user_id, password, category, service, now))
    conn.commit()
    conn.close()

def get_user_passwords(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    passwords = c.execute('SELECT id, password, category, service, created_at FROM passwords WHERE user_id = ? ORDER BY id DESC', (user_id,)).fetchall()
    conn.close()
    return passwords

def delete_password(password_id, user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('DELETE FROM passwords WHERE id = ? AND user_id = ?', (password_id, user_id))
    conn.commit()
    conn.close()

def get_all_passwords(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    passwords = c.execute('SELECT password FROM passwords WHERE user_id = ?', (user_id,)).fetchall()
    conn.close()
    return [p[0] for p in passwords]

# ========== ГЕНЕРАЦИЯ ПАРОЛЕЙ (УНИКАЛЬНЫЕ) ==========
def generate_password(length=12, use_upper=True, use_lower=True, use_digits=True, use_symbols=False):
    chars = ""
    if use_upper: chars += string.ascii_uppercase
    if use_lower: chars += string.ascii_lowercase
    if use_digits: chars += string.digits
    if use_symbols: chars += "!@#$%^&*()_+-=[]{}|;:,.<>?"
    
    if not chars:
        chars = string.ascii_letters + string.digits
    
    return ''.join(random.choice(chars) for _ in range(length))

def generate_unique_password(user_id, length=12, use_upper=True, use_lower=True, use_digits=True, use_symbols=False):
    """Генерирует уникальный пароль, которого нет в БД у пользователя"""
    existing = get_all_passwords(user_id)
    existing_set = set(existing)
    
    for _ in range(100):  # Максимум 100 попыток
        password = generate_password(length, use_upper, use_lower, use_digits, use_symbols)
        if password not in existing_set:
            return password
    return generate_password(length, use_upper, use_lower, use_digits, use_symbols)

def check_password_strength(password):
    """Оценка надёжности пароля"""
    score = 0
    feedback = []
    
    if len(password) >= 8:
        score += 1
    else:
        feedback.append("❌ Слишком короткий (минимум 8 символов)")
    
    if len(password) >= 12:
        score += 1
    
    if any(c.isupper() for c in password):
        score += 1
    else:
        feedback.append("❌ Добавьте заглавные буквы")
    
    if any(c.islower() for c in password):
        score += 1
    else:
        feedback.append("❌ Добавьте строчные буквы")
    
    if any(c.isdigit() for c in password):
        score += 1
    else:
        feedback.append("❌ Добавьте цифры")
    
    if any(c in "!@#$%^&*()_+-=[]{}|;:,.<>?" for c in password):
        score += 1
    else:
        feedback.append("⚠️ Добавьте спецсимволы для надёжности")
    
    if score <= 2:
        strength = "🔴 КРИТИЧЕСКИ СЛАБЫЙ"
        color = "🔴"
    elif score <= 4:
        strength = "🟡 СЛАБЫЙ"
        color = "🟡"
    elif score <= 6:
        strength = "🟢 СРЕДНИЙ"
        color = "🟢"
    else:
        strength = "✅ ОЧЕНЬ СИЛЬНЫЙ"
        color = "✅"
    
    return strength, feedback, score

