def add_user(user_id, username, full_name):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO users (user_id, username, full_name, registered_at) VALUES (?, ?, ?, ?)',
              (user_id, username, full_name, now))
    conn.commit()
    conn.close()

def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, full_name, registered_at, balance, is_admin, is_agent, is_banned FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def get_user_by_id(user_id):
    """Безопасное получение пользователя"""
    user = get_user(user_id)
    if user:
        return {"id": user[0], "username": user[1] or str(user[0]), "name": user[2]}
    return {"id": user_id, "username": str(user_id), "name": str(user_id)}

def get_all_tags(category=None):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    if category:
        c.execute('SELECT id, name, category, price, currency, seller_id, description FROM tags WHERE status = "active" AND category = ?', (category,))
    else:
        c.execute('SELECT id, name, category, price, currency, seller_id, description FROM tags WHERE status = "active"')
    tags = c.fetchall()
    conn.close()
    return tags

def get_tag(tag_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT id, name, price, currency, seller_id, description FROM tags WHERE id = ? AND status = "active"', (tag_id,))
    tag = c.fetchone()
    conn.close()
    return tag

def create_tag_request(seller_id, tag_name, category, price, currency, description):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT INTO tag_requests (seller_id, tag_name, category, price, currency, description, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
              (seller_id, tag_name, category, price, currency, description, now))
    req_id = c.lastrowid
    conn.commit()
    conn.close()
    return req_id

def approve_tag_request(req_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT seller_id, tag_name, category, price, currency, description FROM tag_requests WHERE id = ?', (req_id,))
    req = c.fetchone()
    if req:
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO tags (name, category, price, currency, seller_id, description, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
                  (req[1], req[2], req[3], req[4], req[0], req[5], now))
        c.execute('UPDATE tag_requests SET status = "approved" WHERE id = ?', (req_id,))
    conn.commit()
    conn.close()

def reject_tag_request(req_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('UPDATE tag_requests SET status = "rejected" WHERE id = ?', (req_id,))
    conn.commit()
    conn.close()

