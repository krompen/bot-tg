# ========== ОБРАБОТКА ТЕКСТА ==========
async def handle_text(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    text = update.message.text
    username = update.effective_user.username or str(user_id)
    user_data = get_user(user_id)
    
    if user_data and user_data[6] == 1:
        await update.message.reply_text(f"🚫 ВЫ ЗАБАНЕНЫ!\nПРИЧИНА: {user_data[7]}\n\nОБРАТИТЕСЬ К АДМИНИСТРАТОРУ", reply_markup=back_keyboard())
        return
    
    # Рассылка
    if context.user_data.get("awaiting_broadcast") and is_admin(user_id):
        users = get_all_users()
        sent = 0
        failed = 0
        for u in users:
            try:
                await context.bot.send_message(chat_id=u[0], text=f"📢 РАССЫЛКА ОТ АДМИНА\n\n{text}\n\n— @ciwige")
                sent += 1
            except:
                failed += 1
        await update.message.reply_text(f"✅ ОТПРАВЛЕНО {sent} ПОЛЬЗОВАТЕЛЯМ.\n❌ НЕ ДОСТАВЛЕНО: {failed}")
        context.user_data["awaiting_broadcast"] = False
        return
    
    # Своё описание для подарка
    if context.user_data.get("awaiting_custom_gift"):
        gift_id = context.user_data["awaiting_custom_gift"]
        gift = next((g for g in GIFTS if g["id"] == gift_id), None)
        
        if gift:
            if len(text) > 50:
                await update.message.reply_text("❌ ТЕКСТ НЕ ДОЛЖЕН ПРЕВЫШАТЬ 50 СИМВОЛОВ!", reply_markup=back_keyboard())
                return
            
            total_price = gift['price'] + 10
            context.user_data["custom_gift_text"] = text
            context.user_data["gift_payment"] = {
                "gift_id": gift_id,
                "gift_name": gift['name'],
                "description": text,
                "price": total_price
            }
            
            await update.message.reply_text(
                f"🎁 **{gift['name']}**\n\n"
                f"📝 ВАШ ТЕКСТ: {text}\n\n"
                f"💰 ИТОГО К ОПЛАТЕ: {total_price}⭐\n\n"
                f"✅ Нажми кнопку для оплаты:",
                reply_markup=InlineKeyboardMarkup([
                    [InlineKeyboardButton(f"💳 ОПЛАТИТЬ {total_price}⭐", callback_data=f"gift_pay_{gift_id}_custom")]
                ])
            )
            context.user_data["awaiting_custom_gift"] = False
        return
    
    # Если нет активного ожидания
    if not context.user_data:
        await update.message.reply_text(
            "❓ ИСПОЛЬЗУЙ КНОПКИ МЕНЮ\n\nНажми на кнопку внизу экрана, чтобы выбрать действие.",
            reply_markup=main_keyboard(user_id)
        )
        return
    
    # Продажа тега
    if context.user_data.get("awaiting_sell_tag"):
        try:
            parts = text.split("|")
            if len(parts) < 3:
                await update.message.reply_text("❌ ФОРМАТ: `НАЗВАНИЕ | ЦЕНА | ВАЛЮТА`")
                return
            
            name = parts[0].strip()
            price = int(parts[1].strip())
            currency = parts[2].strip().lower()
            
            if currency not in ["stars", "ton", "usdt", "usd"]:
                await update.message.reply_text("❌ ВАЛЮТЫ: stars, ton, usdt, usd")
                return
            
            await update.message.reply_text("📎 ОТПРАВЬ ДОКАЗАТЕЛЬСТВО ВЛАДЕНИЯ ТЕГОМ\n\nФАЙЛ, ФОТО ИЛИ ТЕКСТ")
            context.user_data["temp_tag"] = (name, price, currency)
            context.user_data["awaiting_tag_proof"] = True
            context.user_data["awaiting_sell_tag"] = False
            
        except ValueError:
            await update.message.reply_text("❌ ЦЕНА ДОЛЖНА БЫТЬ ЧИСЛОМ!")
        return
    
    # Доказательства
    if context.user_data.get("awaiting_tag_proof"):
        name, price, currency = context.user_data["temp_tag"]
        
        if update.message.photo:
            proof = update.message.photo[-1].file_id
            await update.message.reply_text("📸 ФОТО ПОЛУЧЕНО! ОБРАБАТЫВАЮ...")
        elif update.message.document:
            proof = update.message.document.file_id
            await update.message.reply_text("📎 ФАЙЛ ПОЛУЧЕН! ОБРАБАТЫВАЮ...")
        else:
            proof = text
            await update.message.reply_text("📝 ТЕКСТ ПОЛУЧЕН! ОБРАБАТЫВАЮ...")
        
        req_id = create_tag_request(user_id, name, price, currency, "", proof)
        
        await update.message.reply_text(
            f"✅ ЗАЯВКА #{req_id} ОТПРАВЛЕНА!\n\n🏷️ ТЕГ: {name}\n💰 ЦЕНА: {price} {currency}\n\nАДМИН РАССМОТРИТ ЗАЯВКУ",
            reply_markup=main_keyboard(user_id)
        )
        
        await context.bot.send_message(
            chat_id=ADMIN_ID,
            text=f"📝 НОВАЯ ЗАЯВКА #{req_id}\n👤 @{username}\n🏷️ {name}\n💰 {price} {currency}"
        )
        
        context.user_data["awaiting_tag_proof"] = False
        context.user_data["temp_tag"] = None
        return
    
    # Подтверждение оплаты (админ)
    if context.user_data.get("awaiting_confirm_payment") and is_admin(user_id):
        try:
            deal_id = int(text.replace("deal_", ""))
            deal = get_deal(deal_id)
            
            if not deal:
                await update.message.reply_text("❌ СДЕЛКА НЕ НАЙДЕНА!")
                context.user_data["awaiting_confirm_payment"] = False
                return
            
            confirm_buyer_paid(deal_id)
            
            await context.bot.send_message(
