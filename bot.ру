            context.user_data["awaiting_unban"] = False
        except:
            await update.message.reply_text("❌ ОШИБКА!")
            context.user_data["awaiting_unban"] = False
        return
    
    # Ответ на тикет
    if text.startswith("/answer") and is_agent(user_id):
        try:
            parts = text.split(" ", 2)
            ticket_id = int(parts[1])
            answer = parts[2]
            
            close_ticket(ticket_id, answer)
            
            conn = sqlite3.connect(DB_NAME, timeout=10)
            c = conn.cursor()
            c.execute('SELECT user_id FROM tickets WHERE id = ?', (ticket_id,))
            ticket_user = c.fetchone()
            conn.close()
            
            if ticket_user:
                await context.bot.send_message(chat_id=ticket_user[0], text=f"📬 ОТВЕТ НА ТИКЕТ #{ticket_id}\n\n{answer}")
            
            await update.message.reply_text(f"✅ ТИКЕТ #{ticket_id} ЗАКРЫТ.", reply_markup=main_keyboard(show_admin=is_admin(user_id)))
        except:
            await update.message.reply_text("❌ /answer <ID> <ОТВЕТ>")
        return

# ========== ПЛАТЕЖИ ==========
async def pre_checkout_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.pre_checkout_query
    await query.answer(ok=True)

async def successful_payment_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    payload = update.message.successful_payment.invoice_payload
    
    if payload.startswith("gift_"):
        price = int(payload.split("_")[1])
        
        if price == 5:
            gift_text = "🌟 ЛУЧШИЙ ШОП ЮЗОВ — TAGSHOP! 🔥"
        elif price == 10:
            custom_text = context.user_data.get("custom_gift_text", "СПАСИБО ЗА ПОКУПКУ!")
            gift_text = f"✍️ ВАШЕ ОПИСАНИЕ:\n{custom_text}"
        else:
            gift_text = "🎁 ПОДАРОК ОТ TAGSHOP"
        
        await update.message.reply_text(
            f"✅ ОПЛАТА ПРОШЛА УСПЕШНО!\n\n{gift_text}\n\nСПАСИБО ЗА ПОКУПКУ!",
            reply_markup=main_keyboard(show_admin=is_admin(user_id))
        )
        
        await context.bot.send_message(
            chat_id=ADMIN_ID,
            text=f"🎁 НОВАЯ ПОКУПКА ПОДАРКА\n👤 @{update.effective_user.username}\n💰 {price} ⭐"
        )

# ========== ОТЗЫВ О БОТЕ ==========
async def rate_bot_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    
    if data.startswith("rate_bot_"):
        deal_id = int(data.split("_")[2])
        context.user_data["rate_bot_deal"] = deal_id
        
        await query.edit_message_text(
            "⭐ ОЦЕНИ БОТА ОТ 1 ДО 5:",
            reply_markup=InlineKeyboardMarkup([
                [InlineKeyboardButton("1", callback_data="bot_rate_1"),
                 InlineKeyboardButton("2", callback_data="bot_rate_2"),
                 InlineKeyboardButton("3", callback_data="bot_rate_3")],
                [InlineKeyboardButton("4", callback_data="bot_rate_4"),
                 InlineKeyboardButton("5", callback_data="bot_rate_5")],
                [InlineKeyboardButton("🔙 НАЗАД", callback_data="back")]
            ])
        )

async def bot_rate_handler(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    data = query.data
    await query.answer()
    user_id = query.from_user.id
    
    if data.startswith("bot_rate_"):
        rating = int(data.split("_")[2])
        deal_id = context.user_data.get("rate_bot_deal", 0)
        
        await query.edit_message_text(
            "✍️ НАПИШИ КОММЕНТАРИЙ (ИЛИ «-» ДЛЯ ПРОПУСКА):",
            reply_markup=back_keyboard()
        )
        context.user_data["awaiting_bot_review"] = (rating, deal_id)

# ========== ЗАПУСК ==========
def main():
    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("answer", handle_text))
    app.add_handler(PreCheckoutQueryHandler(pre_checkout_handler))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, successful_payment_handler))
    app.add_handler(CallbackQueryHandler(button_handler))
    app.add_handler(CallbackQueryHandler(rate_bot_handler, pattern="rate_bot_"))
    app.add_handler(CallbackQueryHandler(bot_rate_handler, pattern="bot_rate_"))
    app.add_handler(MessageHandler(filters.PHOTO | filters.DOCUMENT | filters.TEXT & ~filters.COMMAND, handle_text))
    
    print("🚀 TAGSHOP BOT v5.0 ЗАПУЩЕН! ВСЕ ОШИБКИ ИСПРАВЛЕНЫ!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()