def add_user(user_id, username, full_name):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    c.execute('INSERT OR IGNORE INTO users (user_id, username, full_name, registered_at) VALUES (?, ?, ?, ?)',
              (user_id, username, full_name, now))
    conn.commit()
    conn.close()

def get_user(user_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT user_id, username, full_name, registered_at, balance, is_admin, is_agent, is_banned FROM users WHERE user_id = ?', (user_id,))
    user = c.fetchone()
    conn.close()
    return user

def get_user_by_id(user_id):
    user = get_user(user_id)
    if user:
        return {"id": user[0], "username": user[1] or str(user[0]), "name": user[2]}
    return {"id": user_id, "username": str(user_id), "name": str(user_id)}

