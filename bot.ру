def approve_tag_request(req_id):
    conn = sqlite3.connect(DB_NAME, timeout=10)
    c = conn.cursor()
    c.execute('SELECT seller_id, tag_name, price, currency, description, proof FROM tag_requests WHERE id = ? AND status = "pending"', (req_id,))
    req = c.fetchone()
    if req:
        now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        c.execute('INSERT INTO tags (name, price, currency, seller_id, description, proof, created_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
                  (req[1], req[2], req[3], req[0], req[4], req[5], now))
        c.execute('UPDATE tag_requests SET status = "approved" WHERE id = ?', (req_id,))
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False

