async def get_philosopher_response(user_id, user_message):
    # Получаем историю
    history = get_conversation_history(user_id, limit=10)
    
    # Формируем контекст
    context = PROMPT + "\n\n"
    context += "Вот предыдущие сообщения от этого человека (помни о них):\n"
    for msg in history:
        role = "Человек" if msg[0] == "user" else "Ты (рассказчик)"
        context += f"{role}: {msg[1]}\n"
    
    context += f"\nЧеловек пишет: {user_message}\n\nТвой ответ (от первого лица, с описанием атмосферы):"
    
    # Генерируем ответ через Gemini
    try:
        response = model.generate_content(context)
        return response.text
    except Exception as e:
        return f"*Тушит сигарету, задумчиво смотрит в потолок*\n\n— Что-то сегодня голос сорвал, мил человек. Давай попозже вернёмся к разговору.\n\n*Зажигает новую сигарету, уходит в туман*\n\n(Ошибка: {str(e)})"

